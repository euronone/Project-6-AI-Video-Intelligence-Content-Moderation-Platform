# ============================================================
# VidShield AI — .gitignore
# ============================================================

# ────────────────────────────────────────────────────────────
# Environment & secrets — NEVER commit these
# ────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
secrets/
credentials.json
service-account*.json

# ────────────────────────────────────────────────────────────
# Frontend — Next.js
# ────────────────────────────────────────────────────────────
frontend/.next/
frontend/out/
frontend/build/
frontend/node_modules/
frontend/.pnp
frontend/.pnp.js
frontend/.yarn/
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/.eslintcache
frontend/coverage/
frontend/playwright-report/
frontend/test-results/
frontend/.vercel
frontend/next-env.d.ts

# ────────────────────────────────────────────────────────────
# Backend — Python / FastAPI
# ────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.Python
pip-log.txt
pip-delete-this-directory.txt
.tox/
.nox/
.coverage
.coverage.*
.cache
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
cover/
*.mo
*.pot
backend/.venv/
backend/venv/
backend/env/
backend/.env
backend/celerybeat-schedule
backend/celerybeat.pid

# ────────────────────────────────────────────────────────────
# Database & migrations artefacts
# ────────────────────────────────────────────────────────────
*.db
*.sqlite3
alembic/versions/*.pyc

# ────────────────────────────────────────────────────────────
# Docker
# ────────────────────────────────────────────────────────────
.dockerignore
docker-compose.override.yml

# ────────────────────────────────────────────────────────────
# Terraform
# ────────────────────────────────────────────────────────────
terraform/.terraform/
terraform/.terraform.lock.hcl
terraform/*.tfstate
terraform/*.tfstate.*
terraform/*.tfstate.backup
terraform/crash.log
terraform/override.tf
terraform/override.tf.json
terraform/*_override.tf
terraform/*_override.tf.json
terraform/.terraformrc
terraform/terraform.rc

# ────────────────────────────────────────────────────────────
# IDE & editors
# ────────────────────────────────────────────────────────────
.vscode/
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ────────────────────────────────────────────────────────────
# OS
# ────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db

# ────────────────────────────────────────────────────────────
# Logs
# ────────────────────────────────────────────────────────────
logs/
*.log
*.log.*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ────────────────────────────────────────────────────────────
# Misc / temp
# ────────────────────────────────────────────────────────────
*.tmp
*.temp
*.bak
*.orig
.turbo/
.cache/
tmp/
temp/
