# ============================================================
# VidShield AI — .gitignore
# ============================================================

# ────────────────────────────────────────────────────────────
# Project-specific files
# ────────────────────────────────────────────────────────────
git-branching-guide.md

# ────────────────────────────────────────────────────────────
# Environment & secrets — NEVER commit these
# ────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
secrets/
credentials.json
service-account*.json

# ────────────────────────────────────────────────────────────
# Frontend — Next.js
# ────────────────────────────────────────────────────────────
frontend/.next/
frontend/out/
frontend/build/
frontend/node_modules/
frontend/.pnp
frontend/.pnp.js
frontend/.yarn/
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/.eslintcache
frontend/coverage/
frontend/playwright-report/
frontend/test-results/
frontend/.jest-cache/
frontend/jest-results/
frontend/.vercel
frontend/next-env.d.ts

# ────────────────────────────────────────────────────────────
# Backend — Python / FastAPI
# ────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.Python
pip-log.txt
pip-delete-this-directory.txt
.tox/
.nox/
.coverage
.coverage.*
.cache
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
cover/
*.mo
*.pot
backend/.venv/
backend/venv/
backend/env/
backend/.env
backend/celerybeat-schedule
backend/celerybeat.pid

# ────────────────────────────────────────────────────────────
# Database & migrations artefacts
# ────────────────────────────────────────────────────────────
*.db
*.sqlite3
alembic/versions/*.pyc

# ────────────────────────────────────────────────────────────
# Docker
# ────────────────────────────────────────────────────────────
.dockerignore
docker-compose.override.yml

# ────────────────────────────────────────────────────────────
# Terraform
# ────────────────────────────────────────────────────────────
terraform/.terraform/
terraform/.terraform.lock.hcl
terraform/*.tfstate
terraform/*.tfstate.*
terraform/*.tfstate.backup
terraform/crash.log
terraform/override.tf
terraform/override.tf.json
terraform/*_override.tf
terraform/*_override.tf.json
terraform/.terraformrc
terraform/terraform.rc

# ────────────────────────────────────────────────────────────
# IDE & editors
# ────────────────────────────────────────────────────────────
.vscode/
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ────────────────────────────────────────────────────────────
# OS
# ────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db

# ────────────────────────────────────────────────────────────
# Logs
# ────────────────────────────────────────────────────────────
logs/
*.log
*.log.*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ────────────────────────────────────────────────────────────
# AI / ML — model artefacts & data
# ────────────────────────────────────────────────────────────
# Model weights & checkpoints
*.pt
*.pth
*.ckpt
*.safetensors
*.onnx
*.pb
*.h5
*.bin
models/
checkpoints/
weights/

# Vector store / embeddings cache
pinecone_cache/
embeddings_cache/
*.faiss
*.index

# LangChain / LangGraph cache
.langchain/
langchain_cache/
langgraph_cache/
langchain.db

# LangSmith tracing (never commit API keys or trace exports)
langsmith_traces/
.langsmith

# Video & audio processing artefacts
frames/
thumbnails/
*.mp4
*.avi
*.mov
*.mkv
*.wav
*.mp3
*.m4a
backend/app/ai/data/
backend/tmp_frames/

# OpenAI / API response caches (never store real API responses in repo)
openai_cache/
response_cache/

# ────────────────────────────────────────────────────────────
# Mock data — local dev persistence (never commit user data)
# ────────────────────────────────────────────────────────────
frontend/.mock-data/

# ────────────────────────────────────────────────────────────
# Misc / temp
# ────────────────────────────────────────────────────────────
*.tmp
*.temp
*.bak
*.orig
.turbo/
.cache/
tmp/
temp/
