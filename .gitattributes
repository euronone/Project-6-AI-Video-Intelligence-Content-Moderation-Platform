# Normalize line endings to LF for all text files
* text=auto eol=lf

# Explicitly force LF for source files
*.py    text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.json  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.md    text eol=lf
*.tf    text eol=lf
*.sh    text eol=lf
*.toml  text eol=lf
*.ini   text eol=lf
*.cfg   text eol=lf
*.txt   text eol=lf
Makefile text eol=lf
Dockerfile text eol=lf
